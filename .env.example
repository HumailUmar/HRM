# Public application URL.
APP_URL="https://app.example.com"

# Server-side secrets. Never expose these through VITE_* variables, client
# settings, source control, or browser storage.
JWT_SECRET="generate-a-long-random-value"
ENCRYPTION_KEY="generate-a-separate-long-random-value"
GEMINI_API_KEY=""
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
# Optional comma-separated Google accounts that are allowed to receive Admin on first sign-in.
ADMIN_EMAILS=""

# Comma-separated absolute browser origins. Wildcards must include protocol and
# a complete subdomain label, e.g. https://*.preview.example.com. Bare * is rejected.
ALLOWED_ORIGINS="https://app.example.com"
